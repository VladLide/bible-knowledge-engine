{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bke:event-type:Migration",
  "title": "Migration",
  "description": "One or more people move from one place to another. Reducer: each living subject's location := to.",
  "type": "object",
  "properties": {
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^person\\.[a-z0-9_-]+$" }
    },
    "from": { "type": "string", "pattern": "^place\\.[a-z0-9_-]+$" },
    "to": { "type": "string", "pattern": "^place\\.[a-z0-9_-]+$" }
  },
  "required": ["subjects", "from", "to"]
}
