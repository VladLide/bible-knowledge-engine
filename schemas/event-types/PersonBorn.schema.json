{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bke:event-type:PersonBorn",
  "title": "PersonBorn",
  "description": "A person begins to exist, at a place. Reducer: person.alive=true, location=place.",
  "type": "object",
  "properties": {
    "person": { "type": "string", "pattern": "^person\\.[a-z0-9_-]+$" },
    "place": { "type": "string", "pattern": "^place\\.[a-z0-9_-]+$" },
    "parents": {
      "type": "array",
      "items": { "type": "string", "pattern": "^person\\.[a-z0-9_-]+$" }
    }
  },
  "required": ["person", "place"]
}
