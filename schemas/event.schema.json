{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bke:event",
  "title": "Event (base)",
  "description": "Base shape every typed event shares. The `type` selects an additional per-type schema in schemas/event-types/.",
  "type": "object",
  "required": ["id", "type", "time", "sources"],
  "properties": {
    "id": { "type": "string", "pattern": "^event\\.[a-z0-9_-]+$" },
    "type": { "type": "string" },
    "time": { "$ref": "#/$defs/time" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "A fact with no source is invalid. Each item is a reference or source id.",
      "items": {
        "type": "string",
        "pattern": "^(reference|source)\\.[a-z0-9_.:-]+$"
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["confirmed", "probable", "possible", "tradition", "unknown"],
      "default": "probable"
    },
    "models": {
      "type": "array",
      "description": "If present, event exists only under these historical models. Absent = all models.",
      "items": { "type": "string" }
    },
    "requires": {
      "type": "array",
      "description": "Escape hatch only. Explicit dependency edges the compiler cannot derive from event semantics.",
      "items": { "type": "string", "pattern": "^event\\.[a-z0-9_-]+$" }
    }
  },
  "$defs": {
    "time": {
      "type": "object",
      "description": "EDTF-subset value, or per-model variants.",
      "oneOf": [
        { "required": ["edtf"] },
        { "required": ["variants"] }
      ],
      "properties": {
        "edtf": { "type": "string" },
        "variants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["model", "edtf"],
            "properties": {
              "model": { "type": "string" },
              "edtf": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
